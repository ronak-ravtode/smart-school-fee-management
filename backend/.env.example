# SmartSchoolFee Backend — Environment Variables
# Copy this file to .env and fill in values

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/smartschoolfee?schema=public"

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-random-64-char-string"

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGIN="https://your-app.vercel.app"

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=5000
