generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Student ──────────────────────────────────────────────────────────────────

model Student {
  id          String    @id @default(uuid()) @map("id")
  name        String    @map("name")
  email       String    @unique @map("email")
  class       String    @map("class")
  section     String    @map("section")
  rollNumber  String    @map("roll_number")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  ledgers StudentFeeLedger[]

  @@unique([rollNumber, class, section])
  @@index([isDeleted])
  @@map("students")
}

// ─── FeeType ──────────────────────────────────────────────────────────────────

model FeeType {
  id          String    @id @default(uuid()) @map("id")
  name        String    @unique @map("name")
  baseAmount  Decimal   @db.Decimal(10, 2) @map("base_amount")
  rules       Json?     @map("rules")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  feeStructures FeeStructure[]

  @@index([isDeleted])
  @@map("fee_types")
}

// ─── FeeStructure ─────────────────────────────────────────────────────────────
// Maps a FeeType to a specific Class + Section combination.

model FeeStructure {
  id         String    @id @default(uuid()) @map("id")
  feeTypeId  String    @map("fee_type_id")
  class      String    @map("class")
  section    String    @map("section")
  amount     Decimal   @db.Decimal(10, 2) @map("amount")
  isDeleted  Boolean   @default(false) @map("is_deleted")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  feeType    FeeType            @relation(fields: [feeTypeId], references: [id], onDelete: Cascade)
  ledgers    StudentFeeLedger[]

  // One active structure per fee-type + class + section
  @@unique([feeTypeId, class, section])
  @@index([class, section])
  @@index([isDeleted])
  @@map("fee_structures")
}

// ─── StudentFeeLedger ─────────────────────────────────────────────────────────
// Core financial record: tracks what a student owes.

model StudentFeeLedger {
  id             String        @id @default(uuid()) @map("id")
  studentId      String        @map("student_id")
  feeStructureId String        @map("fee_structure_id")
  totalAmount    Decimal       @db.Decimal(10, 2) @map("total_amount")
  waivedAmount   Decimal       @default(0) @db.Decimal(10, 2) @map("waived_amount")
  paidAmount     Decimal       @default(0) @db.Decimal(10, 2) @map("paid_amount")
  dueDate        DateTime      @map("due_date")
  status         LedgerStatus  @default(PENDING) @map("status")
  isDeleted      Boolean       @default(false) @map("is_deleted")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure     @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  // Frequently queried combinations
  @@index([studentId])
  @@index([status])
  @@index([studentId, status])
  @@index([dueDate])
  @@index([isDeleted])
  @@map("student_fee_ledgers")
}

// ─── Transaction ──────────────────────────────────────────────────────────────
// Represents an actual payment event.

model Transaction {
  id                  String            @id @default(uuid()) @map("id")
  ledgerId            String            @map("ledger_id")
  amount              Decimal           @db.Decimal(10, 2) @map("amount")
  paymentMethod       PaymentMethod     @map("payment_method")
  transactionRef      String?           @map("transaction_ref")
  receiptNumber       String?           @unique @map("receipt_number")
  status              TransactionStatus @default(PENDING) @map("status")
  chequeNumber        String?           @map("cheque_number")
  chequeBank          String?           @map("cheque_bank")
  chequeIssueDate     DateTime?         @map("cheque_issue_date")
  actualClearedAmount Decimal?          @db.Decimal(10, 2) @map("actual_cleared_amount")
  isDeleted           Boolean           @default(false) @map("is_deleted")
  deletedAt           DateTime?         @map("deleted_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  // Relations
  ledger StudentFeeLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)

  @@index([ledgerId])
  @@index([status])
  @@index([isDeleted])
  @@map("transactions")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CASHIER
}

enum LedgerStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  UPI
  CASH
  CHEQUE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  PENDING_CLEARANCE
  CLEARED
  PARTIALLY_CLEARED
  BOUNCED
}

// ─── Audit Log ───────────────────────────────────────────────────────────────
// Append-only. No UPDATE or DELETE endpoints exist for this model.

model AuditLog {
  id            String      @id @default(cuid())
  timestamp     DateTime    @default(now()) @map("timestamp")
  actorId       String      @map("actor_id")
  actorName     String      @map("actor_name")
  action        AuditAction @map("action")
  entityType    String      @map("entity_type")
  entityId      String      @map("entity_id")
  previousValue Json?       @map("previous_value")
  newValue      Json?       @map("new_value")
  reason        String?     @map("reason")
  ipAddress     String?     @map("ip_address")

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([timestamp])
  @@index([timestamp, entityType, action])
  @@map("audit_logs")
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  WAIVED
  PENALTY_APPLIED
  CHEQUE_CLEARED
  CHEQUE_BOUNCED
  PAYMENT_RECORDED
  PAYMENT_REVERSED
  BULK_PAYMENT
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @map("id")
  email        String   @unique @map("email")
  passwordHash String   @map("password_hash")
  name         String   @map("name")
  role         Role     @default(CASHIER) @map("role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}
